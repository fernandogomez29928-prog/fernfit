# ── WHOOP (already set up) ──
WHOOP_CLIENT_ID=a71da43e-cfb9-41c4-840b-bafc965946fd
WHOOP_CLIENT_SECRET=your_client_secret_here
WHOOP_REDIRECT_URI=https://fernfit.vercel.app/api/whoop-callback

# ── Supabase (Phase 1 — database) ──
# From Supabase dashboard → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
# Use the SERVICE ROLE key (secret). Server-side only — never in the browser.
SUPABASE_SERVICE_KEY=your_service_role_key_here

# ── Claude / Anthropic (Phase 4 — AI coach) ──
# From console.anthropic.com → API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Optional: override the model (defaults to claude-sonnet-4-6)
# COACH_MODEL=claude-opus-4-8
